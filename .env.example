# Stripe (BR) — obter em https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISH_KEY=pk_test_...
# Mesma chave publishable exposta ao Vite (browser)
VITE_STRIPE_PUBLISH_KEY=pk_test_...

# SuperFrete — obter em https://painel.superfrete.com/
SUPER_FRETE_API=eyJhbGci...

# Opcional: porta do backend Express (default 4000)
# SERVER_PORT=4000

# --- Deploy na Vercel (site + API no mesmo domínio) ---
# No painel Vercel → Settings → Environment Variables:
#   Production (e Preview, se quiseres testar PRs):
#   STRIPE_SECRET_KEY, STRIPE_PUBLISH_KEY, SUPER_FRETE_API, VITE_STRIPE_PUBLISH_KEY
# Firebase Auth → Authorized domains: adiciona teu-dominio.vercel.app e o domínio customizado.
