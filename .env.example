# Stripe (BR) — obter em https://dashboard.stripe.com/apikeys
# Nunca commits chaves reais; usa só placeholders ou variáveis na Vercel.
STRIPE_SECRET_KEY=
STRIPE_PUBLISH_KEY=
VITE_STRIPE_PUBLISH_KEY=

# Webhook Stripe → notificação (n8n / WhatsApp)
# URL no Stripe: https://SEU_DOMINIO/api/checkout/stripe-webhook | Evento: payment_intent.succeeded
STRIPE_WEBHOOK_SECRET=

# Opcional — URL do fluxo n8n (há default no código se vazio)
# N8N_NOTIFY_WEBHOOK_URL=https://…/webhook/…
# Opcional — E.164 sem + (há default no código)
# N8N_NOTIFY_WHATSAPP=

# SuperFrete — token no painel https://painel.superfrete.com/
SUPER_FRETE_API=

# Opcional: e-mail admin para o botão “testar n8n” nos KPIs (há default no código)
# ADMIN_EMAIL=

# Opcional: porta do backend Express (default 4000)
# SERVER_PORT=4000

# --- Vercel → Settings → Environment Variables ---
# STRIPE_SECRET_KEY, STRIPE_PUBLISH_KEY, STRIPE_WEBHOOK_SECRET, SUPER_FRETE_API, VITE_STRIPE_PUBLISH_KEY
# Firebase Auth → Authorized domains: domínio da loja
