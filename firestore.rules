rules_version = '2';

// KING Oversized — Firestore Security Rules
// Deploy: firebase deploy --only firestore:rules
//        (ou copie este conteúdo no Firebase Console → Firestore → Regras)
//
// Admin: quem tiver email == kingoversized@gmail.com em auth.token.email.
// Qualquer coleção não listada abaixo é automaticamente negada.

service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================
    // Helpers
    // =========================================================
    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn()
        && request.auth.token.email == "kingoversized@gmail.com";
    }
    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function incoming() { return request.resource.data; }
    function current()  { return resource.data; }
    function changedKeys() {
      return incoming().diff(current()).affectedKeys();
    }
    function hasOnly(keys) {
      return changedKeys().hasOnly(keys);
    }
    function isString(v) { return v is string; }
    function isNum(v)    { return v is number; }
    function isBool(v)   { return v is bool; }
    function isList(v)   { return v is list; }
    function isMap(v)    { return v is map; }

    // =========================================================
    // USERS — cada autenticado lê/escreve só o próprio doc
    // =========================================================
    match /users/{userId} {
      allow read:   if isSelf(userId) || isAdmin();
      allow create: if isSelf(userId)
                    && incoming().keys().hasOnly([
                         'uid','email','displayName','photoURL','createdAt','updatedAt'
                       ]);
      allow update: if isSelf(userId)
                    // bloqueia alteração de uid/email após criação
                    && !changedKeys().hasAny(['uid','email']);
      allow delete: if false; // remoção só pelo console / Cloud Function
    }

    // =========================================================
    // PRODUCTS — leitura pública; CRUD só admin
    // =========================================================
    match /products/{productId} {
      allow read: if true;

      allow create: if isAdmin()
                    && isString(incoming().name)
                    && isNum(incoming().price)
                    && incoming().price >= 0
                    && isList(incoming().images);

      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // =========================================================
    // ORDERS — usuário cria/lê os próprios; admin tudo
    // =========================================================
    match /orders/{orderId} {
      // Cria ao finalizar checkout. userId precisa bater com auth.uid.
      allow create: if isSignedIn()
                    && incoming().userId == request.auth.uid
                    && isString(incoming().userEmail)
                    && isList(incoming().items)
                    && isNum(incoming().total)
                    && incoming().total >= 0
                    && isString(incoming().status)
                    && isMap(incoming().shipping);

      allow read:   if isAdmin()
                    || (isSignedIn() && current().userId == request.auth.uid);

      // Usuário dono nunca altera pedido após criação; só admin.
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // =========================================================
    // STAMPS — leitura pública; CRUD só admin
    // =========================================================
    match /stamps/{stampId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // =========================================================
    // COUPONS — leitura pública (checkout valida cupom).
    // CRUD só admin. Usuário logado pode incrementar usedCount
    // em +1 (e nada mais) ao finalizar pagamento.
    // =========================================================
    match /coupons/{couponId} {
      allow read: if true;

      allow create: if isAdmin()
                    && isString(incoming().code)
                    && isNum(incoming().discountPercent);
      allow delete: if isAdmin();

      allow update: if isAdmin()
                    || (
                      isSignedIn()
                      && hasOnly(['usedCount'])
                      && isNum(incoming().usedCount)
                      && incoming().usedCount == current().usedCount + 1
                    );
    }

    // =========================================================
    // CATEGORIES — chips de filtro dinâmicos na loja.
    // Leitura pública; CRUD só admin.
    // =========================================================
    match /categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // =========================================================
    // COLLECTIONS — grupos customizados de produtos (ex.: "Páscoa 2026").
    // Leitura pública; CRUD só admin.
    // =========================================================
    match /collections/{collectionId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // =========================================================
    // LEADS — qualquer visitante cria (form de WhatsApp na home).
    // Admin lista/remove.
    // =========================================================
    match /leads/{leadId} {
      allow create: if isString(incoming().phoneDigits)
                    && incoming().phoneDigits.size() >= 10
                    && incoming().phoneDigits.size() <= 13;
      allow read, update, delete: if isAdmin();
    }

    // =========================================================
    // Catch-all — qualquer coleção não listada acima é bloqueada.
    // =========================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
