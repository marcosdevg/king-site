rules_version = '2';
// Publique no Firebase Console → Storage → Regras (ou use `firebase deploy --only storage`).
// Ajuste o e-mail se mudar o admin.
service firebase.storage {
  match /b/{bucket}/o {
    match /products/gallery/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.auth.token.email == "kingoversized@gmail.com";
    }
  }
}
